# See https://www.dartlang.org/guides/libraries/private-files

# Files and directories created by pub
.dart_tool/
.packages
build/
#pubspec.lock

# Directory created by dartdoc
doc/api/

# dotenv environment variables file
.env*

# Avoid committing generated Javascript files:
*.dart.js
*.info.json      # Produced by the --dump-info flag.
*.js             # When generated by dart2js. Don't specify *.js if your
                 # project includes source files written in JavaScript.
*.js_
*.js.deps
*.js.map

# Flutter plugins and dependencies
.flutter-plugins
.flutter-plugins-dependencies

# Flutter build and platform-specific directories
.macos/
windows/
linux/
ios/Flutter/.last_build_id
**/GeneratedPluginRegistrant.*

# IntelliJ IDEA and Android Studio-related files
.idea/
*.iml
*.iws
.idea/workspace.xml
.idea/libraries/
.idea/modules.xml
.idea/vcs.xml
.idea/codeStyles/
.idea/inspectionProfiles/
.idea/caches/
.idea/modules/
.idea/shelf/
.idea/scopes/
.idea/dictionaries/

# JetBrains specific
*.ipr
out/

# Android related
local.properties
*.jks
app/google-services.json
app/google-services.plist

# Firebase crashlytics
crashlytics-build.properties

# Flutter dependencies
.flutter/
.DS_Store

# Сгенерированные файлы сборки
*.apk
*.aar
*.ap_
*.aab
*.bin

# Локальные файлы Gradle
.gradle/
android/app/.cxx/

# Отладочные файлы
*/Debug/*
*/Release/*